{
  "name": "fern-hermes-avatar",
  "version": "0.1.0",
  "description": "Electron + Vue + PixiJS Live2D desktop overlay for Hermes.",
  "type": "module",
  "main": "dist/main/index.js",
  "author": "Hermes",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "compile": "npm run typecheck && electron-vite build",
    "build": "npm run compile && electron-builder",
    "dist": "npm run build"
  },
  "dependencies": {
    "@pixi/app": "^7.4.0",
    "@pixi/core": "^7.4.0",
    "@pixi/display": "^7.4.0",
    "@pixi/extensions": "^7.4.0",
    "@pixi/sprite": "^7.4.0",
    "@pixi/ticker": "^7.4.0",
    "pinia": "^2.1.0",
    "pixi-live2d-display": "^0.4.0",
    "vue": "^3.4.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^3.1.0",
    "typescript": "^5.3.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.0.0"
  }
}
